CORENAME=JTTAITOB
JTFRAME_BUTTONS=2
JTFRAME_JOY_UDRL
JTFRAME_WIDTH=320
JTFRAME_HEIGHT=224
JTFRAME_PXLCLK=6
JTFRAME_COLORW=5
JTFRAME_HEADER=8
# SDRAM bank start addresses (from ROM layout)
# BA0: 68000 ROM (512KB) + work RAM
# BA1: Z80 ROM (64KB) + YM2610 ADPCM samples
# BA2: GFX tiles (BG/FG 16x16 + TX 8x8)
# BA3: Sprite GFX
JTFRAME_BA1_START=0x080000
SND_START=0x080000
ADPCMA_START=0x090000
JTFRAME_BA2_START=0x110000
GFX_TX_START=0x110000
GFX_BG_START=0x130000
JTFRAME_BA3_START=0x230000
JTFRAME_IOCTL_RD=4096
LOADROM
SIM_INPUTS
